# Al Assema — Caddy reverse proxy for a single-domain VPS deployment.
# Caddy gets a free HTTPS certificate automatically (Let's Encrypt).
#
# Architecture (one domain, NO CORS needed because same-origin):
#   https://your-domain.com/         → static frontend (app/dist, SPA fallback)
#   https://your-domain.com/api/*    → Next.js backend on localhost:3000
#
# Because the frontend and API share an origin, build the frontend with
#   VITE_API_URL=/api   (already wired in deploy/deploy.sh)
# and you can leave CORS_ALLOWED_ORIGINS empty in api/.env.
#
# Install Caddy: https://caddyserver.com/docs/install   (Ubuntu: apt install caddy)
# Put this file at /etc/caddy/Caddyfile, edit the domain + root path, then:
#   sudo caddy fmt --overwrite /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

your-domain.com {
	encode zstd gzip

	# API → Next.js backend (PM2 on :3000)
	handle /api/* {
		reverse_proxy localhost:3000
	}

	# Everything else → static SPA with client-side routing fallback
	handle {
		root * /var/www/alassema/dist
		try_files {path} /index.html
		file_server
	}
}
