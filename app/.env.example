# Al Assema — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored and never committed. This template must stay free of
# real secrets — it is committed to git.

# ── API ────────────────────────────────────────────────────────────────────────
# Base URL of the Al Assema backend REST API (the api/ Next.js app), no trailing
# slash. The backend serves routes under /api, so include that suffix.
#   Local dev:  http://localhost:3000/api
#   Production: https://your-backend-host/api
# Leave blank to run entirely on localStorage / mock data (default for local dev).
VITE_API_URL=http://localhost:3000/api

# Optional static API key forwarded as X-Api-Key on every request. Only needed if
# the backend sets API_KEY; this must match that secret. NOT a Supabase key.
VITE_API_KEY=

# ── CAPTCHA (optional: bot protection on public forms) ──────────────────────────
# Cloudflare Turnstile site key. When set, the lead / review / feedback /
# site-review forms render a Turnstile widget and send its token. Leave blank to
# disable (forms submit with no widget — honeypot + rate limit still apply).
# MUST pair with the backend's TURNSTILE_SECRET_KEY, or submits are rejected.
VITE_TURNSTILE_SITE_KEY=
