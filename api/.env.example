# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Use the Supabase "Connection string". For production with the transaction
# pooler (pgbouncer), set DATABASE_URL to the pooled URL and DIRECT_URL to the
# direct (session) URL, then uncomment `directUrl` in prisma/schema.prisma.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# ── Supabase (Auth + Storage) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=""
# Token lifetime (e.g. "1h", "30m", "7d"). Defaults to 7d. Keep short in prod.
JWT_TTL="7d"

# ── First admin (npm run create-admin) ────────────────────────────────────────
# Used ONLY by `npm run create-admin` to bootstrap the first ADMIN login. The
# catalog seed does not create any admin. Set these as one-off env vars when
# running the command; do not keep real credentials committed.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Site Admin"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API. Leave empty in local
# dev to reflect any origin. In production set this to the site origin(s).
CORS_ALLOWED_ORIGINS=""
# Optional shared gate matching the frontend's VITE_API_KEY.
API_KEY=""

# ── Security / integrations (later phases) ────────────────────────────────────
RECAPTCHA_SECRET_KEY=""
UPSTASH_REDIS_URL=""
# Email notifications (Phase 11). Without RESEND_API_KEY, lead emails are skipped
# (lead creation still succeeds). RESEND_FROM must be a verified sender.
RESEND_API_KEY=""
RESEND_FROM="Al Assema <onboarding@resend.dev>"
