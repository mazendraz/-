# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Serverful (VPS / long-running Node process): use the Session pooler for BOTH
# DATABASE_URL and DIRECT_URL. The direct "db.[PROJECT-REF].supabase.co" host is
# IPv6-only, which most VPS hosts can't reach — the session pooler (port 5432)
# supports IPv4 and behaves like a direct connection (safe for `prisma migrate`).
# Get the exact host from Settings → Database → Session pooler — host prefix is
# usually "aws-0-" but can be "aws-1-" for some projects/regions.
# User must be "postgres.[PROJECT-REF]" (not just "postgres") with the pooler.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# ── Supabase (Auth + Storage) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=""
# Token lifetime (e.g. "1h", "30m", "7d"). Defaults to 7d. Tokens live in the
# browser's localStorage and CANNOT be revoked before they expire (logout only
# drops them client-side) — so keep this SHORT in production. Recommended: "1d".
# To force-revoke a session immediately, deactivate the user (isActive=false);
# getAuthUser rejects inactive users on the next request.
JWT_TTL="1d"

# ── First admin (npm run create-admin) ────────────────────────────────────────
# Used ONLY by `npm run create-admin` to bootstrap the first ADMIN login. The
# catalog seed does not create any admin. Set these as one-off env vars when
# running the command; do not keep real credentials committed.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Site Admin"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API. Leave empty in local
# dev to reflect any origin. In production set this to the site origin(s).
CORS_ALLOWED_ORIGINS=""
# Optional shared gate matching the frontend's VITE_API_KEY.
API_KEY=""
# Trusted reverse-proxy hops in front of the app (each appends one
# X-Forwarded-For entry). Caddy alone = 1. Add a CDN/load-balancer → set to 2.
# Used by the rate limiter to find the real client IP (rateLimit.ts).
TRUSTED_PROXY_HOPS="1"

# ── Rate limiting (optional: multi-instance / serverless) ─────────────────────
# Without these the limiter is in-memory (per-process; fine for single-instance
# PM2 fork). Set BOTH to use Upstash Redis so limits hold across restarts/instances.
# From the Upstash console → your database → "REST API".
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── CAPTCHA (optional: bot protection on public submit forms) ─────────────────
# Set ONE secret to require a CAPTCHA on lead/site-review/review submits. When
# unset, verification is skipped (the honeypot + rate limit still apply).
# IMPORTANT: enabling a secret REQUIRES the frontend to render the matching
# widget and send its token (VITE_TURNSTILE_SITE_KEY / VITE_RECAPTCHA_SITE_KEY),
# or every submit is rejected. Turnstile is preferred when both are set.
TURNSTILE_SECRET_KEY=""
RECAPTCHA_SECRET_KEY=""

# ── Error reporting (optional) ────────────────────────────────────────────────
# Set a Sentry DSN to ship unhandled 500s to Sentry (over the HTTP envelope API,
# no SDK). Errors are always logged regardless.
SENTRY_DSN=""

# ── Email notifications (optional) ────────────────────────────────────────────
# Without RESEND_API_KEY, lead emails to providers are skipped (lead creation
# still succeeds). RESEND_FROM must be a verified sender on your Resend account.
RESEND_API_KEY=""
RESEND_FROM="Al Assema <onboarding@resend.dev>"
