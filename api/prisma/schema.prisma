// Al Assema — Prisma schema
// Contract source of truth: ../backend-plan.md §3 + app/src/lib/apiTypes.ts
// Stack: Next.js API Routes · Supabase (Postgres) · Prisma 7

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: the connection URL lives in prisma.config.ts (for Migrate) and is
  // passed to the PrismaClient constructor via a driver adapter (see src/lib/prisma.ts).
  provider = "postgresql"
}

// Company visibility — controlled by admins. The public UI shows ACTIVE only.
enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Values map (at the API boundary) to the frontend LeadStatus:
// "New" | "Contacted" | "In Progress" | "Completed" | "Cancelled"
enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  PROVIDER
}

// Visitor messages submitted from a company page ("Report a problem" / suggestion
// / general inquiry). Maps (at the API boundary) to the frontend FeedbackType:
// "problem" | "suggestion" | "inquiry".
enum FeedbackType {
  PROBLEM
  SUGGESTION
  INQUIRY
}

// Moderation state for a portfolio project. Provider-submitted projects start
// PENDING and only appear publicly once an admin sets them APPROVED. Admin-created
// projects are APPROVED on creation.
enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String // the frontend calls it label, not name
  description String   @db.Text
  icon        String // Material Symbols icon name
  cover       String? // ApiCategory.cover — category cover image
  isActive    Boolean  @default(true)
  // Optional per-page SEO overrides (admin-set). Null → frontend falls back to
  // the label/description-derived defaults.
  metaTitle       String?
  metaDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies Company[]

  // count in the frontend = number of ACTIVE companies, computed live (not stored).

  @@index([slug])
  @@index([isActive])
}

model Company {
  id                String        @id @default(uuid())
  categoryId        String
  slug              String        @unique
  name              String
  tagline           String // short one-liner
  about             String        @db.Text
  logo              String
  cover             String // large cover image
  services          String[] // Postgres text[]
  gallery           String[] // gallery image URLs
  badges            String[] // ["Licensed", "Award-Winning"]
  phone             String
  location          String
  yearsExperience   Int           @default(0)
  responseTime      String // "within 2 hours"
  verifiedSince     String // "2021"
  completedProjects Int           @default(0) // manual admin number (!= projects.length)
  // aggregate cache — recomputed from Review on any change, UNLESS ratingOverridden
  // is true, in which case an admin set rating/reviewCount manually and the review
  // recompute leaves them alone (see reviews.service recompute). Clearing the flag
  // recomputes from real reviews again.
  rating            Float         @default(0)
  reviewCount       Int           @default(0)
  ratingOverridden  Boolean       @default(false)
  featured          Boolean       @default(true)
  verified          Boolean       @default(false)
  status            CompanyStatus @default(ACTIVE)
  // internal contact fields for notifications — NOT returned in the public payload
  email             String?
  whatsapp          String?
  // Optional per-page SEO overrides (admin-set). Null → frontend falls back to
  // the name/tagline-derived defaults.
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  projects  Project[]
  reviews   Review[]
  leads     Lead[]
  users     User[]
  feedbacks Feedback[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
}

model Project {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  img         String // matches ApiProject.img + data.ts
  description String   @db.Text
  year        String // display string e.g. "2024"
  sortOrder   Int      @default(0)
  // Curated for the homepage "Featured Projects" showcase (admin-set).
  featured    Boolean  @default(false)
  // Moderation state. New rows default to PENDING (provider submissions); admin
  // creations are set APPROVED in the service. Only APPROVED show publicly.
  status      ProjectStatus @default(PENDING)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([featured])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  companyId String
  // The completed lead this review came from, for verified customer reviews; null
  // for curated/seeded admin reviews. UNIQUE → enforces one review per lead at the
  // DB level (the one-time customer review invariant). Postgres allows many NULLs,
  // so curated reviews don't collide. See reviews.service submitFromLead.
  leadId    String?  @unique
  author    String // matches ApiReview.author
  avatar    String // initial letter as fallback
  rating    Int // 1..5
  text      String   @db.Text
  date      String // "March 2024" (display string)
  district  String // matches ApiReview.district
  // true = submitted by a real customer on a COMPLETED lead (shows a "Verified"
  // badge). false = curated/seeded by an admin. See reviews.service submitFromLead.
  verified  Boolean  @default(false)
  // Moderation gate. Customer submissions start unapproved (hidden + excluded from
  // the rating aggregate) until an admin approves them. Admin-curated reviews are
  // created approved. New rows default false; existing rows backfilled to true.
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Deleting a lead keeps its (verified) review but unlinks it (SetNull). Deleting
  // the company cascades both via companyId, so there's no conflict.
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([approved])
}

model Lead {
  id           String     @id @default(uuid())
  refNumber    String     @unique // AA-YYYYMMDD-XXXX — generated server-side
  // High-entropy secret (generated at creation) that gates public status tracking
  // and the one-time review, replacing the guessable phone number. Nullable so
  // leads created before this column existed fall back to phone-tail matching.
  trackingToken String?
  companyId    String
  service      String // requested service (text)
  customerName String // ApiLead.name
  phone        String
  district     String
  budget       String
  description  String     @db.Text
  status       LeadStatus @default(NEW)
  // Set once the customer leaves a (verified) review for this lead — gates the
  // one-time review flow so a completed request can be reviewed exactly once.
  reviewedAt   DateTime?
  createdAt    DateTime   @default(now()) // returned as epoch ms (Number) in the API
  updatedAt    DateTime   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // companySlug + companyName are returned derived from this relation.
  // The (at most one) verified review submitted for this completed lead.
  review  Review?

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(PROVIDER)
  companyId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([companyId])
}

// Web Push subscription for a user's browser/device. One row per device (a user
// may enable notifications on phone + laptop). `endpoint` is the push service URL
// and is globally unique. Deleted automatically when the push service reports the
// subscription is gone (404/410) — see push.service. Cascades with the user.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String // client public key (base64url) for payload encryption
  auth      String // client auth secret (base64url)
  userAgent String? // for the user to identify which device this is
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Visitor-submitted platform testimonials shown on the homepage. New submissions
// are held (visible=false) for admin moderation before they appear publicly.
model SiteReview {
  id        String   @id @default(uuid())
  name      String
  district  String
  rating    Int // 1..5
  text      String   @db.Text
  visible   Boolean  @default(false)
  createdAt DateTime @default(now()) // returned as epoch ms in the API

  @@index([visible])
  @@index([createdAt])
}

// Visitor-submitted messages tied to a specific company ("Report a problem" /
// suggestion / inquiry from the company page). Surfaced to admins for triage;
// isRead marks whether an admin has seen it.
model Feedback {
  id        String       @id @default(uuid())
  companyId String
  type      FeedbackType @default(PROBLEM)
  name      String?
  phone     String?
  message   String       @db.Text
  isRead    Boolean      @default(false)
  createdAt DateTime     @default(now()) // returned as epoch ms in the API

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isRead])
  @@index([createdAt])
}

// Simple key/value store for global toggles (e.g. site_reviews_enabled).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Append-only audit trail of sensitive/destructive admin actions (deletes, status
// and role/active changes, account creation). Recorded fail-open so a logging
// failure never breaks the action. actorEmail is denormalized so the record stays
// meaningful even if the actor account is later deleted.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorEmail String
  action     String // e.g. "company.delete", "company.status", "user.update"
  entity     String // e.g. "Company", "User", "Lead"
  entityId   String
  meta       String? // optional JSON string with extra context (e.g. new status)
  createdAt  DateTime @default(now()) // returned as epoch ms in the API

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([actorId])
}
